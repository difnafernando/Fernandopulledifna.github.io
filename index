<script>
  // Custom cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx - 6 + 'px';
    cursor.style.top = my - 6 + 'px';
  });

  function animateRing() {
    rx += (mx - rx) * 0.12;
    ry += (my - ry) * 0.12;
    ring.style.left = rx - 18 + 'px';
    ring.style.top = ry - 18 + 'px';
    requestAnimationFrame(animateRing);
  }
  animateRing();

  document.querySelectorAll('a, button, .photo-upload-zone, .project-img-placeholder, .skill-tag').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.style.transform = 'scale(2)';
      ring.style.transform = 'scale(1.5)';
      ring.style.opacity = '0.8';
    });
    el.addEventListener('mouseleave', () => {
      cursor.style.transform = 'scale(1)';
      ring.style.transform = 'scale(1)';
      ring.style.opacity = '0.5';
    });
  });

  // Typing animation
  const words = ['Python Developer', 'ML Engineer', 'Data Analyst', 'Dashboard Creator'];
  let wi = 0, ci = 0, typing = true;
  const typingEl = document.getElementById('typingText');

  function type() {
    if (typing) {
      if (ci < words[wi].length) {
        typingEl.textContent = words[wi].slice(0, ++ci);
        typingEl.className = 'typing-text';
        setTimeout(type, 80);
      } else {
        typing = false;
        setTimeout(type, 2000);
      }
    } else {
      if (ci > 0) {
        typingEl.textContent = words[wi].slice(0, --ci);
        setTimeout(type, 40);
      } else {
        typing = true;
        wi = (wi + 1) % words.length;
        setTimeout(type, 300);
      }
    }
  }
  type();

  // Intersection observer for scroll animations
  const observer = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), 
          entry.target.dataset.index ? entry.target.dataset.index * 100 : 0);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.timeline-item, .cert-card').forEach(el => observer.observe(el));

  // Profile photo upload
  document.getElementById('photoUpload').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      const img = document.getElementById('photoPreview');
      img.src = ev.target.result;
      img.style.display = 'block';
      document.getElementById('photoZone').style.display = 'none';
      document.getElementById('photoStats').style.display = 'grid';
    };
    reader.readAsDataURL(file);
  });

  // Project image uploads
  function triggerProjectUpload(idx) {
    document.getElementById('projUpload' + idx).click();
  }

  [0,1,2,3].forEach(idx => {
    document.getElementById('projUpload' + idx).addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        const img = document.getElementById('projImg' + idx);
        img.src = ev.target.result;
        img.style.display = 'block';
        img.previousElementSibling.style.display = 'none';
      };
      reader.readAsDataURL(file);
    });
  });

  // CV download
  let cvBlob = null;
  document.getElementById('cvUpload').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    cvBlob = file;
    document.getElementById('cvUploadHint').textContent = '✓ CV uploaded: ' + file.name;
    document.getElementById('cvUploadHint').style.color = 'var(--accent3)';
    document.getElementById('cvUploadHint').onclick = null;
  });

  function downloadCV(e) {
    if (!cvBlob) {
      e.preventDefault();
      document.getElementById('cvUpload').click();
      return;
    }
    e.preventDefault();
    const url = URL.createObjectURL(cvBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'Fernando_Pulle_Difna_CV.pdf';
    a.click();
    URL.revokeObjectURL(url);
  }

  // Smooth active nav indicator
  const sections = document.querySelectorAll('[id]');
  const navLinks = document.querySelectorAll('.nav-links a');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(s => {
      if (window.scrollY >= s.offsetTop - 100) current = s.id;
    });
    navLinks.forEach(a => {
      a.style.color = a.getAttribute('href') === '#' + current ? 'var(--accent)' : '';
    });
  });
</script>
